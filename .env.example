# Obsidian MCP Configuration
# Copy this to .env and fill in your values for local development
# For Claude Desktop, credentials are passed via the config file

# Single vault mode
OBSIDIAN_VAULT_PATH=/path/to/your/vault
OBSIDIAN_VAULT_NAME=My Vault

# Multi-vault mode (Phase 4) - JSON object of vault name -> path
# OBSIDIAN_VAULTS={"platform":"/path/to/platform","helena":"/path/to/helena"}

# Ollama configuration (for semantic search)
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
