{
  "name": "@influencentricity/mcp-obsidian",
  "version": "2.0.0",
  "description": "Unified multi-vault Obsidian MCP server. Direct filesystem access with wikilink support, backlinks, semantic search, frontmatter queries, and vault analytics.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-obsidian": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "knowledge-base",
    "rag",
    "semantic-search",
    "wikilinks",
    "influencentricity",
    "claude"
  ],
  "author": "Influencentricity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Influencentricity/mcp-obsidian.git"
  },
  "bugs": {
    "url": "https://github.com/Influencentricity/mcp-obsidian/issues"
  },
  "homepage": "https://github.com/Influencentricity/mcp-obsidian#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
